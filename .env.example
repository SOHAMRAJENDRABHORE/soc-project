# Copy this file to .env and fill in your real keys.
# .env is in .gitignore so your keys never get committed.

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_MODEL=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Threat intel (all free tiers)
VIRUSTOTAL_API_KEY=your_vt_key_here          # https://www.virustotal.com/gui/my-apikey
ABUSEIPDB_API_KEY=your_abuseipdb_key_here    # https://www.abuseipdb.com/account/api
OTX_API_KEY=your_otx_key_here                # https://otx.alienvault.com/api

# Behavior flags
ENRICHMENT_TIMEOUT_SECONDS=15
LOG_LEVEL=INFO

# ---------- Central Server ----------
# Where the central server listens (laptop side)
CENTRAL_SERVER_HOST=0.0.0.0
CENTRAL_SERVER_PORT=8080
# Shared secret. Agent must send this in the Authorization header.
# Pick anything long and random — `python -c "import secrets; print(secrets.token_urlsafe(32))"`
AGENT_AUTH_TOKEN=change_me_to_a_long_random_string
# How long jobs wait before being marked expired
JOB_EXPIRY_SECONDS=600
# How many seconds without heartbeat before agent is "offline"
AGENT_OFFLINE_AFTER_SECONDS=60
# SQLite DB file (relative to project root)
CENTRAL_DB_PATH=central_server.db

# ---------- Endpoint Agent ----------
# URL of the central server (FROM the agent's perspective)
# On the same machine: http://127.0.0.1:8080
# On a different machine: http://<laptop-IP>:8080
CENTRAL_SERVER_URL=http://127.0.0.1:8080
# How often to poll for jobs (seconds)
AGENT_POLL_INTERVAL=5
# Optional: pin the agent_id (otherwise auto-generated and persisted)
# AGENT_ID=

# ---------- Forensic tool paths (on the AGENT machine) ----------
# Volatility 3 — empty string means "use whatever `vol` is on PATH"
VOLATILITY_BINARY=vol
# Ghidra headless analyzer path — point to analyzeHeadless on the agent
# Linux: /opt/ghidra/support/analyzeHeadless
# Windows: C:\ghidra\support\analyzeHeadless.bat
GHIDRA_HEADLESS=
# Demo sample files (so the agent has something to analyze without live capture)
SAMPLE_MEMORY_DUMP=
SAMPLE_BINARY=

# ---------- Onboarding Agent ----------
# Generate ONCE with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Then paste below. NEVER lose this key — it encrypts all tenant credentials.
ONBOARDING_ENCRYPTION_KEY=

# How often (seconds) the Onboarding Agent polls each tenant for new alerts.
# 30 = good for demo, 300 = closer to real-world cadence.
ONBOARDING_POLL_INTERVAL=30

# Where mock-provider JSON files live (relative to project root).
ONBOARDING_SAMPLE_DIR=onboarding_agent/sample_alerts

# ---------- More threat intel (free tiers) ----------
GREYNOISE_API_KEY=          # https://viz.greynoise.io/account/api-key (free)
SHODAN_API_KEY=             # https://account.shodan.io/ (free)
# URLhaus, ThreatFox, MalwareBazaar need no keys (abuse.ch public APIs)

# ---------- ngrok tunnel (for remote agents on different networks) ----------
# Sign up free at https://dashboard.ngrok.com → Your Authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
# Optional: your free static domain from https://dashboard.ngrok.com/domains
# e.g. my-name.ngrok-free.app  (leave blank to use a random URL each time)
NGROK_DOMAIN=

# ---------- VIP gating (Action Bot) ----------
# Comma-separated list of usernames or endpoint identifiers considered VIP.
# When the target endpoint matches a VIP, Action Bot REQUIRES explicit human approval
# even in single-workflow auto-execution mode.
VIP_USERS=ceo,cfo,executive
